{
  "name": "better-auth-bili-basic",
  "version": "0.0.5",
  "description": "A plugin for better-auth that provides basic authentication features for bili accounts.",
  "keywords": [
    "authentication",
    "better-auth",
    "bili",
    "bilibili",
    "plugin"
  ],
  "homepage": "https://github.com/rinnein/better-auth-bili-basic#readme",
  "bugs": {
    "url": "https://github.com/rinnein/better-auth-bili-basic/issues"
  },
  "license": "MIT",
  "author": "rinnein",
  "contributors": [
    "rinnein (https://github.com/rinnein)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rinnein/better-auth-bili-basic.git"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "prepare": "vp config"
  },
  "dependencies": {
    "better-auth": "^1.6.24",
    "ky": "^2.0.2",
    "nanoid": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "packageManager": "bun@1.3.14",
  "inlinedDependencies": {
    "@better-fetch/fetch": "1.3.1"
  }
}
